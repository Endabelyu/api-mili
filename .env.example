# =============================================================================
# Personal Finance Tracker — API Server Environment Variables
# =============================================================================
# Copy this file to .env and fill in your own values.
# Never commit the real .env file to version control.
#
# REQUIRED variables must be set before the server will start.
# OPTIONAL variables are safe to leave blank — features will degrade gracefully.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Required)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:password@localhost:5432/financetracker

# PostgreSQL credentials — used by docker-compose to provision the DB container
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=financetracker

# -----------------------------------------------------------------------------
# Authentication - Better Auth (Required)
# -----------------------------------------------------------------------------
# Generate a 32+ character secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your-32-character-secret-here
BETTER_AUTH_URL=http://localhost:3005

# The URL of the React frontend — used for CORS whitelisting
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Application Settings (Required)
# -----------------------------------------------------------------------------
NODE_ENV=development
# Port the Hono server binds to (docker-compose maps this to 4006 in production)
PORT=3005

# -----------------------------------------------------------------------------
# pgAdmin — Database GUI (Optional, docker-compose only)
# -----------------------------------------------------------------------------
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin123

# -----------------------------------------------------------------------------
# OAuth Providers (Optional)
# Uncomment and set these to enable OAuth authentication
# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# -----------------------------------------------------------------------------
# Email/SMTP (Optional)
# Required for password reset and email notifications
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@example.com

# -----------------------------------------------------------------------------
# Feature Flags (Optional)
# -----------------------------------------------------------------------------
# ENABLE_BETA_FEATURES=false
# ENABLE_EXPORT_NOTIFICATIONS=true

# -----------------------------------------------------------------------------
# Alerting / Monitoring — Telegram (Optional)
# Leave blank to disable Telegram alerts
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# TELEGRAM_CHAT_ID=your-telegram-group-or-channel-id
# TELEGRAM_TOPIC_FRONTEND=frontend-topic-thread-id
# TELEGRAM_TOPIC_BACKEND=backend-topic-thread-id

# -----------------------------------------------------------------------------
# Monitoring Stack — Grafana (docker-compose.monitoring.yml only)
# -----------------------------------------------------------------------------
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=changeme

# -----------------------------------------------------------------------------
# Error Tracking — Sentry (Optional)
# https://docs.sentry.io/platforms/node/
# Leave SENTRY_DSN blank to disable — backend runs fine without Sentry in dev
# -----------------------------------------------------------------------------
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_TRACES_SAMPLE_RATE=0.1

# -----------------------------------------------------------------------------
# Receipt OCR — Claude Vision (Optional)
# Leave blank to disable AI scanning — users will only see "Scan Gratis"
# Get your key at: https://console.anthropic.com/
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-api03-...
# OCR_DAILY_LIMIT=10
